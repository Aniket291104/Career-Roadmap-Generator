PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ai-career-roadmap?retryWrites=true&w=majority

# Redis (falls back to local memory if empty/invalid)
REDIS_URL=redis://localhost:6379

# Auth Secrets
JWT_ACCESS_SECRET=your_super_secret_jwt_access_token_12345
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_token_67890
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# AI Engines (Gemini)
GEMINI_API_KEY=your_google_gemini_api_key

# Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Payments (Stripe)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Mailer (Nodemailer SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password
FROM_EMAIL=no-reply@aicareerroadmap.com

# Client Config
CLIENT_URL=http://localhost:3000
